@model List<ApiProjeWeb.UI.Dtos.ServiceDtos.ResultServiceDto>

<section id="why-us" class="why-us section light-background">

            <div class="container">

                <div class="row gy-4">

                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="why-box">
                            <h3>Neden Yummy</h3>
                            <p>
                                Yummy, adını yalnızca lezzeti ifade eden bir kelimeden değil, misafirlerine yaşatmak istediği deneyimden alır. Bizim için “yummy”, ilk lokmada yüzünüzde oluşan gülümseme, sofrada paylaşılan keyifli anlar ve damakta kalan unutulmaz tatların ortak adıdır. Bu yüzden Yummy’de her tabak özenle hazırlanır, her tarif taze ve kaliteli malzemelerle hayat bulur. Amacımız yalnızca yemek sunmak değil; sizi lezzet, sıcaklık ve samimiyetle dolu bir sofrada buluşturmaktır.
                            </p>
                            <div class="text-center">
                                <a href="#" class="more-btn"><span>Learn More</span> <i class="bi bi-chevron-right"></i></a>
                            </div>
                        </div>
                    </div><!-- End Why Box -->

                    <div class="col-lg-8 d-flex align-items-stretch">
                        <div class="row gy-4" data-aos="fade-up" data-aos-delay="200">
                            @foreach(var item in Model)
                             {
                            <div class="col-xl-4">
                                <div class="icon-box d-flex flex-column justify-content-center align-items-center">
                                    <i class="@item.IconUrl"></i>
                                    <h4>@item.Title</h4>
                                    <p>@item.Description</p>
                                </div>
                            </div><!-- End Icon Box -->
                            }

                        </div>
                    </div>

                </div>

            </div>

        </section>

