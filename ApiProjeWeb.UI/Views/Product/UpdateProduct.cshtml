@model GetProductByIdDto
@{
    ViewData["Title"] = "UpdateProduct";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Ürün Güncelleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <input type="hidden" asp-for="ProductId" />

                            <label>Ürün Adı</label>
                            <input type="text" asp-for="ProductName" class="form-control" />
                            <br />

                            <label>Ürün Fiyatı</label>
                            <input type="text" asp-for="Price" class="form-control" />
                            <br />

                            <label>Ürün Görsel Url</label>
                            <input type="text" asp-for="ProductUrl" class="form-control" />
                            <br />

                            <label>Ürün Açıklaması</label>
                            <textarea asp-for="ProductDescription" class="form-control" rows="5"></textarea>
                            <br />

                            <label>Kategori Id</label>
                            <input type="text" asp-for="CategoryId" class="form-control" />
                            <br />

                            <button class="btn btn-primary">Ürünü Düzenle</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>