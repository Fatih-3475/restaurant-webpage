@model CreateChefDto
@{
    ViewData["Title"] = "CreateChef";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Yeni Şef Ekleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <label>Şef Adı Soyadı</label>
                            <input type="text" asp-for="NameSurname" class="form-control" />
                            <br />
                            <label>Şef Başlık</label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Şef Açıklama</label>
                            <input type="text" asp-for="Description" class="form-control" />
                            <br />
                            <label>Şef Görsel Url</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />
                            <button class="btn btn-primary">Yeni Şef Oluştur</button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
    








